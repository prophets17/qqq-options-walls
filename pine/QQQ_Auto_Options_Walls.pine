//@version=6
indicator("QQQ Auto Options Walls", overlay=true)

repo = input.string("YOUR_GITHUB_USERNAME/YOUR_REPO_NAME", "GitHub Repo")
seedFile = input.string("qqq_walls", "Seed File Name")
showSecondaryWalls = input.bool(true, "Show Secondary Walls")
showGammaFlip = input.bool(true, "Show Gamma Flip")

callWall  = request.seed(repo, seedFile, call_wall)
callWall2 = request.seed(repo, seedFile, call_wall_2)
callWall3 = request.seed(repo, seedFile, call_wall_3)
putWall   = request.seed(repo, seedFile, put_wall)
putWall2  = request.seed(repo, seedFile, put_wall_2)
putWall3  = request.seed(repo, seedFile, put_wall_3)
gammaFlip = request.seed(repo, seedFile, gamma_flip)

plot(callWall, "Call Wall", color=color.red, linewidth=3, style=plot.style_linebr)
plot(putWall, "Put Wall", color=color.green, linewidth=3, style=plot.style_linebr)
plot(showGammaFlip ? gammaFlip : na, "Gamma Flip", color=color.yellow, linewidth=3, style=plot.style_linebr)

plot(showSecondaryWalls ? callWall2 : na, "Call Wall 2", color=color.new(color.red, 30), linewidth=2, style=plot.style_linebr)
plot(showSecondaryWalls ? callWall3 : na, "Call Wall 3", color=color.new(color.red, 55), linewidth=2, style=plot.style_linebr)
plot(showSecondaryWalls ? putWall2 : na, "Put Wall 2", color=color.new(color.green, 30), linewidth=2, style=plot.style_linebr)
plot(showSecondaryWalls ? putWall3 : na, "Put Wall 3", color=color.new(color.green, 55), linewidth=2, style=plot.style_linebr)

nearPct = input.float(0.20, "Near Wall Threshold %", step=0.05)

pctDistance(level) =>
    math.abs(close - level) / close * 100.0

nearCall = not na(callWall) and pctDistance(callWall) <= nearPct
nearPut = not na(putWall) and pctDistance(putWall) <= nearPct
nearFlip = showGammaFlip and not na(gammaFlip) and pctDistance(gammaFlip) <= nearPct

bgcolor(nearCall ? color.new(color.red, 90) : na)
bgcolor(nearPut ? color.new(color.green, 90) : na)
bgcolor(nearFlip ? color.new(color.yellow, 88) : na)

alertcondition(nearCall, title="Near Call Wall", message="QQQ is near the primary call wall.")
alertcondition(nearPut, title="Near Put Wall", message="QQQ is near the primary put wall.")
alertcondition(nearFlip, title="Near Gamma Flip", message="QQQ is near the gamma flip.")
